package ui;

import db.DBConnection;
import javax.swing.*;
import javax.swing.border.*;
import java.awt.*;
import java.awt.event.*;
import java.sql.*;

public class DashboardFrame extends JFrame {

    private JPanel contentPanel;
    private JLabel pageTitle;

    static final Color BG_DARK     = new Color(18, 18, 18);
    static final Color BG_SIDEBAR  = new Color(22, 22, 22);
    static final Color BG_CONTENT  = new Color(26, 26, 26);
    static final Color GREEN_MAIN  = new Color(34, 197, 94);
    static final Color GREEN_DARK  = new Color(22, 163, 74);
    static final Color TEXT_WHITE  = new Color(240, 240, 240);
    static final Color TEXT_GRAY   = new Color(140, 140, 140);
    static final Color CARD_BG     = new Color(32, 32, 32);
    static final Color BORDER_C    = new Color(40, 40, 40);
    static final Color HOVER_BG    = new Color(34, 197, 94, 25);

    public DashboardFrame() {
        setTitle("Grand Stay Hotel - Dashboard");
        setSize(950, 600);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setResizable(false);

        JPanel root = new JPanel(new BorderLayout());
        root.setBackground(BG_DARK);
        setContentPane(root);

        // ── SIDEBAR ──
        JPanel sidebar = new JPanel();
        sidebar.setBackground(BG_SIDEBAR);
        sidebar.setPreferredSize(new Dimension(220, 600));
        sidebar.setLayout(new BoxLayout(sidebar, BoxLayout.Y_AXIS));
        sidebar.setBorder(new MatteBorder(0, 0, 0, 1, BORDER_C));

        // Logo area
        JPanel logoPanel = new JPanel();
        logoPanel.setBackground(BG_SIDEBAR);
        logoPanel.setLayout(new BoxLayout(logoPanel, BoxLayout.Y_AXIS));
        logoPanel.setBorder(new EmptyBorder(28, 20, 28, 20));
        logoPanel.setAlignmentX(Component.LEFT_ALIGNMENT);
        logoPanel.setMaximumSize(new Dimension(220, 110));

        JLabel hotelIcon = new JLabel("🏨");
        hotelIcon.setFont(new Font("Segoe UI Emoji", Font.PLAIN, 30));
        hotelIcon.setAlignmentX(Component.CENTER_ALIGNMENT);
        logoPanel.add(hotelIcon);

        JLabel hotelName = new JLabel("Grand Stay");
        hotelName.setFont(new Font("Arial", Font.BOLD, 16));
        hotelName.setForeground(TEXT_WHITE);
        hotelName.setAlignmentX(Component.CENTER_ALIGNMENT);
        logoPanel.add(hotelName);

        JLabel hotelSub = new JLabel("Hotel Management");
        hotelSub.setFont(new Font("Arial", Font.PLAIN, 11));
        hotelSub.setForeground(GREEN_MAIN);
        hotelSub.setAlignmentX(Component.CENTER_ALIGNMENT);
        logoPanel.add(hotelSub);

        sidebar.add(logoPanel);

        // Divider
        JSeparator sep = new JSeparator();
        sep.setForeground(BORDER_C);
        sep.setMaximumSize(new Dimension(220, 1));
        sidebar.add(sep);
        sidebar.add(Box.createVerticalStrut(15));

        // Nav buttons
        JButton[] navBtns = {
                makeSidebarBtn("🏠", "Dashboard"),
                makeSidebarBtn("🛏", "View Rooms"),
                makeSidebarBtn("📋", "All Bookings"),
                makeSidebarBtn("➕", "Add Booking"),
        };

        for (JButton btn : navBtns) sidebar.add(btn);

        sidebar.add(Box.createVerticalGlue());

        // Logout
        JButton logoutBtn = makeSidebarBtn("🚪", "Logout");
        logoutBtn.setForeground(new Color(239, 68, 68));
        sidebar.add(logoutBtn);
        sidebar.add(Box.createVerticalStrut(20));

        root.add(sidebar, BorderLayout.WEST);

        // ── MAIN CONTENT ──
        JPanel mainArea = new JPanel(new BorderLayout());
        mainArea.setBackground(BG_CONTENT);

        // Top bar
        JPanel topBar = new JPanel(new BorderLayout());
        topBar.setBackground(BG_DARK);
        topBar.setPreferredSize(new Dimension(730, 60));
        topBar.setBorder(new CompoundBorder(
                new MatteBorder(0, 0, 1, 0, BORDER_C),
                new EmptyBorder(0, 25, 0, 25)));

        pageTitle = new JLabel("Dashboard");
        pageTitle.setFont(new Font("Arial", Font.BOLD, 20));
        pageTitle.setForeground(TEXT_WHITE);
        topBar.add(pageTitle, BorderLayout.WEST);

        JLabel dateLabel = new JLabel(new java.util.Date().toString().substring(0, 16));
        dateLabel.setFont(new Font("Arial", Font.PLAIN, 12));
        dateLabel.setForeground(TEXT_GRAY);
        topBar.add(dateLabel, BorderLayout.EAST);

        mainArea.add(topBar, BorderLayout.NORTH);

        // Content panel
        contentPanel = new JPanel();
        contentPanel.setBackground(BG_CONTENT);
        contentPanel.setBorder(new EmptyBorder(25, 25, 25, 25));
        mainArea.add(contentPanel, BorderLayout.CENTER);

        root.add(mainArea, BorderLayout.CENTER);

        // Load dashboard by default
        showDashboard();

        // Nav actions
        navBtns[0].addActionListener(e -> { pageTitle.setText("Dashboard");    showDashboard(); });
        navBtns[1].addActionListener(e -> { pageTitle.setText("View Rooms");   new RoomsFrame(); });
        navBtns[2].addActionListener(e -> { pageTitle.setText("All Bookings"); new BookingFrame(); });
        navBtns[3].addActionListener(e -> { pageTitle.setText("Add Booking");  new AddBookingFrame(); });
        logoutBtn.addActionListener(e -> { dispose(); new LoginFrame(); });

        setVisible(true);
    }

    private void showDashboard() {
        contentPanel.removeAll();
        contentPanel.setLayout(new BorderLayout());

        // Stats row
        JPanel statsRow = new JPanel(new GridLayout(1, 3, 18, 0));
        statsRow.setOpaque(false);
        statsRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 120));

        int[] stats = getStats();
        statsRow.add(makeStatCard("🛏  Total Rooms",    String.valueOf(stats[0]), new Color(59, 130, 246)));
        statsRow.add(makeStatCard("✅  Available",       String.valueOf(stats[1]), GREEN_MAIN));
        statsRow.add(makeStatCard("📋  Total Bookings", String.valueOf(stats[2]), new Color(249, 115, 22)));

        contentPanel.add(statsRow, BorderLayout.NORTH);

        // Recent bookings table
        JLabel recentLabel = new JLabel("Recent Bookings");
        recentLabel.setFont(new Font("Arial", Font.BOLD, 15));
        recentLabel.setForeground(TEXT_WHITE);
        recentLabel.setBorder(new EmptyBorder(22, 0, 12, 0));

        JPanel tablePanel = new JPanel(new BorderLayout());
        tablePanel.setOpaque(false);
        tablePanel.add(recentLabel, BorderLayout.NORTH);

        String[] cols = {"Customer", "Room", "Check-In", "Check-Out", "Status"};
        javax.swing.table.DefaultTableModel model = new javax.swing.table.DefaultTableModel(cols, 0) {
            public boolean isCellEditable(int r, int c) { return false; }
        };

        try {
            Connection con = DBConnection.getConnection();
            String sql = "SELECT b.customer_name, r.room_number, b.check_in, b.check_out, b.status " +
                    "FROM bookings b JOIN rooms r ON b.room_id=r.id ORDER BY b.id DESC LIMIT 5";
            ResultSet rs = con.createStatement().executeQuery(sql);
            while (rs.next()) {
                model.addRow(new Object[]{
                        rs.getString("customer_name"), rs.getString("room_number"),
                        rs.getString("check_in"), rs.getString("check_out"), rs.getString("status")
                });
            }
            con.close();
        } catch (Exception e) { e.printStackTrace(); }

        JTable table = new JTable(model);
        table.setBackground(CARD_BG);
        table.setForeground(TEXT_WHITE);
        table.setFont(new Font("Arial", Font.PLAIN, 13));
        table.setRowHeight(32);
        table.setShowGrid(false);
        table.setIntercellSpacing(new Dimension(0, 0));
        table.getTableHeader().setBackground(new Color(28, 28, 28));
        table.getTableHeader().setForeground(TEXT_GRAY);
        table.getTableHeader().setFont(new Font("Arial", Font.BOLD, 12));
        table.getTableHeader().setBorder(new MatteBorder(0, 0, 1, 0, BORDER_C));
        table.setSelectionBackground(HOVER_BG);

        JScrollPane scroll = new JScrollPane(table);
        scroll.setBackground(CARD_BG);
        scroll.getViewport().setBackground(CARD_BG);
        scroll.setBorder(new LineBorder(BORDER_C, 1, true));
        tablePanel.add(scroll, BorderLayout.CENTER);

        contentPanel.add(tablePanel, BorderLayout.CENTER);

        contentPanel.revalidate();
        contentPanel.repaint();
    }

    private JPanel makeStatCard(String label, String value, Color accent) {
        JPanel card = new JPanel(new BorderLayout());
        card.setBackground(CARD_BG);
        card.setBorder(BorderFactory.createCompoundBorder(
                new LineBorder(BORDER_C, 1, true),
                new EmptyBorder(18, 22, 18, 22)));

        JLabel valLbl = new JLabel(value);
        valLbl.setFont(new Font("Arial", Font.BOLD, 38));
        valLbl.setForeground(accent);

        JLabel txtLbl = new JLabel(label);
        txtLbl.setFont(new Font("Arial", Font.PLAIN, 13));
        txtLbl.setForeground(TEXT_GRAY);

        card.add(valLbl, BorderLayout.CENTER);
        card.add(txtLbl, BorderLayout.SOUTH);
        return card;
    }

    private JButton makeSidebarBtn(String icon, String label) {
        JButton btn = new JButton(icon + "  " + label) {
            public void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                if (getModel().isRollover() || getModel().isPressed()) {
                    g2.setColor(HOVER_BG);
                    g2.fillRoundRect(8, 2, getWidth() - 16, getHeight() - 4, 8, 8);
                }
                super.paintComponent(g);
            }
        };
        btn.setFont(new Font("Segoe UI Emoji", Font.PLAIN, 13));
        btn.setForeground(TEXT_GRAY);
        btn.setBackground(new Color(0, 0, 0, 0));
        btn.setBorderPainted(false);
        btn.setContentAreaFilled(false);
        btn.setHorizontalAlignment(SwingConstants.LEFT);
        btn.setBorder(new EmptyBorder(10, 22, 10, 22));
        btn.setMaximumSize(new Dimension(220, 44));
        btn.setAlignmentX(Component.LEFT_ALIGNMENT);
        btn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        btn.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) { btn.setForeground(GREEN_MAIN); btn.repaint(); }
            public void mouseExited(MouseEvent e)  { btn.setForeground(TEXT_GRAY);  btn.repaint(); }
        });
        return btn;
    }

    private int[] getStats() {
        int total = 0, available = 0, bookings = 0;
        try {
            Connection con = DBConnection.getConnection();
            ResultSet r1 = con.createStatement().executeQuery("SELECT COUNT(*) FROM rooms");
            if (r1.next()) total = r1.getInt(1);
            ResultSet r2 = con.createStatement().executeQuery("SELECT COUNT(*) FROM rooms WHERE status='Available'");
            if (r2.next()) available = r2.getInt(1);
            ResultSet r3 = con.createStatement().executeQuery("SELECT COUNT(*) FROM bookings");
            if (r3.next()) bookings = r3.getInt(1);
            con.close();
        } catch (Exception e) { e.printStackTrace(); }
        return new int[]{total, available, bookings};
    }
}
