package ui;

import db.DBConnection;
import javax.swing.*;
import javax.swing.border.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.sql.*;

import static ui.DashboardFrame.*;

public class RoomsFrame extends JFrame {

    public RoomsFrame() {
        setTitle("View Rooms");
        setSize(700, 480);
        setLocationRelativeTo(null);

        JPanel root = new JPanel(new BorderLayout());
        root.setBackground(BG_CONTENT);
        root.setBorder(new EmptyBorder(20, 20, 20, 20));
        setContentPane(root);

        // Header
        JLabel title = new JLabel("🛏  All Rooms");
        title.setFont(new Font("Arial", Font.BOLD, 20));
        title.setForeground(TEXT_WHITE);
        title.setBorder(new EmptyBorder(0, 0, 15, 0));
        root.add(title, BorderLayout.NORTH);

        // Table
        String[] cols = {"ID", "Room No", "Type", "Price / Night", "Status"};
        DefaultTableModel model = new DefaultTableModel(cols, 0) {
            public boolean isCellEditable(int r, int c) { return false; }
        };

        try {
            Connection con = DBConnection.getConnection();
            ResultSet rs = con.createStatement().executeQuery("SELECT * FROM rooms");
            while (rs.next()) {
                String status = rs.getString("status");
                model.addRow(new Object[]{
                        rs.getInt("id"),
                        rs.getString("room_number"),
                        rs.getString("type"),
                        "₹ " + rs.getString("price"),
                        status
                });
            }
            con.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
        }

        JTable table = new JTable(model) {
            public Component prepareRenderer(javax.swing.table.TableCellRenderer r, int row, int col) {
                Component c = super.prepareRenderer(r, row, col);
                String status = (String) getValueAt(row, 4);
                if ("Available".equals(status))    c.setForeground(GREEN_MAIN);
                else if ("Booked".equals(status))  c.setForeground(new Color(239, 68, 68));
                else                               c.setForeground(TEXT_GRAY);
                c.setBackground(isRowSelected(row) ? HOVER_BG : CARD_BG);
                return c;
            }
        };
        styleTable(table);

        JScrollPane scroll = new JScrollPane(table);
        scroll.getViewport().setBackground(CARD_BG);
        scroll.setBorder(new LineBorder(BORDER_C, 1));
        root.add(scroll, BorderLayout.CENTER);

        // Close btn
        JButton closeBtn = makeBtn("Close");
        closeBtn.addActionListener(e -> dispose());
        JPanel south = new JPanel(new FlowLayout(FlowLayout.RIGHT));
        south.setBackground(BG_CONTENT);
        south.setBorder(new EmptyBorder(12, 0, 0, 0));
        south.add(closeBtn);
        root.add(south, BorderLayout.SOUTH);

        setVisible(true);
    }

    static void styleTable(JTable table) {
        table.setBackground(CARD_BG);
        table.setForeground(TEXT_WHITE);
        table.setFont(new Font("Arial", Font.PLAIN, 13));
        table.setRowHeight(32);
        table.setShowGrid(false);
        table.setIntercellSpacing(new Dimension(0, 0));
        table.getTableHeader().setBackground(new Color(28, 28, 28));
        table.getTableHeader().setForeground(TEXT_GRAY);
        table.getTableHeader().setFont(new Font("Arial", Font.BOLD, 12));
        table.getTableHeader().setBorder(new MatteBorder(0, 0, 1, 0, BORDER_C));
        table.setSelectionBackground(HOVER_BG);
    }

    static JButton makeBtn(String text) {
        JButton btn = new JButton(text) {
            public void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                if (getModel().isPressed())       g2.setColor(GREEN_DARK);
                else if (getModel().isRollover()) g2.setColor(new Color(40, 210, 100));
                else                              g2.setColor(GREEN_MAIN);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
                g2.setColor(Color.WHITE);
                g2.setFont(new Font("Arial", Font.BOLD, 13));
                FontMetrics fm = g2.getFontMetrics();
                g2.drawString(getText(), (getWidth() - fm.stringWidth(getText())) / 2,
                        (getHeight() + fm.getAscent() - fm.getDescent()) / 2);
            }
        };
        btn.setPreferredSize(new Dimension(110, 38));
        btn.setBorderPainted(false);
        btn.setContentAreaFilled(false);
        btn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        return btn;
    }
}
